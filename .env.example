# Cxy Package Registry Configuration
# Copy this file to .env and update with your values

# Server port (default: 8080)
PORT=8080

# SQLite database file path (default: registry.db)
DB_PATH=registry.db

# Public URL of the registry (used in API responses)
# Update this to your production domain
REGISTRY_URL=http://localhost:8080

# JWT secret for token signing (REQUIRED)
# Generate a secure random string for production:
#   openssl rand -base64 32
JWT_SECRET=change-me-to-a-secure-random-string
