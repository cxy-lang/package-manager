test "recordDownload - increments counters" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

    var metadata = PackageMetadata{
        name:        "test".S,
        version:     "1.0.0".S,
        description: "Test".S,
        author:      "Author".S,
        license:     "MIT".S,
        repository:  "https://github.com/test/test.git".S,
        homepage:    "".S
    }

    var deps = Vector[DependencySpec]()
    var request = PublishRequest{
        repository:   "https://github.com/test/test.git".S,
        tag:          "v1.0.0".S,
        commit:       "abc123".S,
        checksum:     "sha256:test".S,
        metadata:     &&metadata,
        readme:       "".S,
        dependencies: &&deps
    }

    repo.publishPackage(&request)

    ok!(repo.getTotalDownloadCount() == 0)

    repo.recordDownload("test", "1.0.0")
    ok!(repo.getTotalDownloadCount() == 1)

    repo.recordDownload("test", "1.0.0")
    ok!(repo.getTotalDownloadCount() == 2)
}

test "yankVersion - marks version as yanked" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

    var metadata = PackageMetadata{
        name:        "test".S,
        version:     "1.0.0".S,
        description: "Test".S,
        author:      "Author".S,
        license:     "MIT".S,
        repository:  "https://github.com/test/test.git".S,
        homepage:    "".S
    }

    var deps = Vector[DependencySpec]()
    var request = PublishRequest{
        repository:   "https://github.com/test/test.git".S,
        tag:          "v1.0.0".S,
        commit:       "abc123".S,
        checksum:     "sha256:test".S,
        metadata:     &&metadata,
        readme:       "".S,
        dependencies: &&deps
    }

    repo.publishPackage(&request)

    var versionOpt = repo.getVersion("test", "1.0.0")
    ok!(!!versionOpt)
    ok!(!versionOpt&.yanked)

    repo.yankVersion("test", "1.0.0")

    var yankedOpt = repo.getVersion("test", "1.0.0")
    ok!(!!yankedOpt)
    ok!(yankedOpt&.yanked)
}

test "validateToken - returns false for nonexistent token" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

    ok!(!repo.validateToken("nonexistent"))
}

test "createToken and validateToken - creates and validates token" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

    var tokenId = repo.createToken("hash123", "test-token")
    ok!(tokenId > 0)

    ok!(repo.validateToken("hash123"))
    ok!(!repo.validateToken("wrong-hash"))
}

test "getDependencies - returns dependencies for version" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

    var deps = Vector[DependencySpec]()
    deps.push(DependencySpec{
        name:               "dep1".S,
        repository:         "https://github.com/test/dep1.git".S,
        version_constraint: "^1.0.0".S,
        is_dev:             false
    })
    deps.push(DependencySpec{
        name:               "dep2".S,
        repository:         "https://github.com/test/dep2.git".S,
        version_constraint: "*".S,
        is_dev:             true
    })

    var metadata = PackageMetadata{
        name:        "test".S,
        version:     "1.0.0".S,
        description: "Test".S,
        author:      "Author".S,
        license:     "MIT".S,
        repository:  "https://github.com/test/test.git".S,
        homepage:    "".S
    }

    var request = PublishRequest{
        repository:   "https://github.com/test/test.git".S,
        tag:          "v1.0.0".S,
        commit:       "abc123".S,
        checksum:     "sha256:test".S,
        metadata:     &&metadata,
        readme:       "".S,
        dependencies: &&deps
    }

    repo.publishPackage(&request)

    var retrievedDeps = repo.getDependenciesForVersion("test", "1.0.0")
    ok!(retrievedDeps.size() == 2)
    ok!(retrievedDeps.[0].name == "dep1")
    ok!(retrievedDeps.[1].name == "dep2")
    ok!(!retrievedDeps.[0].is_dev)
    ok!(retrievedDeps.[1].is_dev)
}

test "getRecentPackages - returns recent packages" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

