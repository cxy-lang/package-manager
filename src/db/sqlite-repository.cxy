            repository:   "https://github.com/test/test.git".S,
            tag:          "v1.0.0".S,
            commit:       "abc123".S,
            checksum:     "sha256:test".S,
            metadata:     &&metadata,
            readme:       "".S,
            dependencies: &&deps
