test "listVersions - returns all versions sorted" {
    var repo = SQLitePackageRepository.open(":memory:")
    repo.initialize()

    // Publish multiple versions
    var versions = ["0.1.0", "0.2.0", "1.0.0"]
    for ver, idx : versions {
        var metadata = PackageMetadata{
            name:        "test".S,
            version:     String(ver),
            description: "Test".S,
            author:      "Author".S,
            license:     "MIT".S,
            repository:  "https://github.com/test/test.git".S,
            homepage:    "".S
        }

        var request = PublishRequest{
            repository:   "https://github.com/test/test.git".S,
            tag:          f"v{ver}",
            commit:       "abc123".S,
            checksum:     "sha256:test".S,
            metadata:     &&metadata,
            readme:       "".S,
            dependencies: Vector[DependencySpec]()
        }

        repo.publishPackage(&request, 0)
    }

    var allVersions = repo.listVersions("test")
    ok!(allVersions.size() == 3)
    // Should be sorted newest first
    ok!(allVersions.[0].version == "1.0.0")
}
