module package_manager_api_handlers

import { Server, Request, Response, Status } from "stdlib/http.cxy"
import { parse } from "stdlib/json.cxy"
import { Vector } from "stdlib/vector.cxy"
import { RepoProvider, AuthMiddleware } from "./middleware.cxy"
import { PublishRequest, VersionSummary, ApiKey, User } from "../models.cxy"
import { PackageRepository } from "../repository.cxy"
import "./response.cxy" as response

/// Type alias for our configured server
pub type Endpoint = Server[RepoProvider, AuthMiddleware]

// ============================================================================
// Route Registration Groups
// ============================================================================

/// Register health check endpoint
pub func health(ep: &Endpoint): void {
    var auth = ep.middleware[AuthMiddleware]()
    auth.exempt(ep("GET /api/v1/health", (@unused req: &const Request, resp: &Response) => {
        handleHealth(resp)
    }))
}

/// Register package endpoints
pub func packages(ep: &Endpoint): void {
    var auth = ep.middleware[AuthMiddleware]()

    // Search/list packages
    auth.exempt(ep("GET /api/v1/packages", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var query = req.qparam("q", "")
        var limitStr = req.qparam("limit")
        var offsetStr = req.qparam("offset")
        var sortParam = req.qparam("sort", "relevance")

        var limit = !!limitStr ? limitStr&.toi[i32]() : 20 as i32
        var offset = !!offsetStr ? offsetStr&.toi[i32]() : 0 as i32

        handleSearchPackages(resp, ctx.repo, query, limit, offset, sortParam)
    }).setAttrs({ parseQueryParams: true }))

    // Get package details
    auth.exempt(ep("GET /api/v1/packages/{name}", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var nameOpt = req.param("name")
        if !nameOpt {
            response.badRequest(resp, "Missing package name".S)
            return
        }
        handleGetPackage(resp, ctx.repo, __copy!(*nameOpt))
    }))

    // Get package README (raw markdown)
    auth.exempt(ep("GET /api/v1/packages/{name}/readme", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var nameOpt = req.param("name")
        if !nameOpt {
            response.badRequest(resp, "Missing package name".S)
            return
        }
        handleGetReadme(resp, ctx.repo, __copy!(*nameOpt))
    }))

    // List versions
    auth.exempt(ep("GET /api/v1/packages/{name}/versions", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var nameOpt = req.param("name")
        if !nameOpt {
            response.badRequest(resp, "Missing package name".S)
            return
        }
        handleListVersions(resp, ctx.repo, __copy!(*nameOpt))
    }))

    // Get specific version
    auth.exempt(ep("GET /api/v1/packages/{name}/{version}", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var nameOpt = req.param("name")
        var versionOpt = req.param("version")

        if !nameOpt {
            response.badRequest(resp, "Missing package name".S)
            return
        }
        if !versionOpt {
            response.badRequest(resp, "Missing version".S)
            return
        }

        handleGetVersion(resp, ctx.repo, __copy!(*nameOpt), __copy!(*versionOpt))
    }))

    // Download tracking
    auth.exempt(ep("POST /api/v1/packages/{name}/{version}/download", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var nameOpt = req.param("name")
        var versionOpt = req.param("version")

        if !nameOpt || !versionOpt {
            response.badRequest(resp, "Missing package name or version".S)
            return
        }

        handleDownload(resp, ctx.repo, __copy!(*nameOpt), __copy!(*versionOpt))
    }))

    // Yank version (owner or admin)
    auth.requireUser(ep("POST /api/v1/packages/{name}/{version}/yank", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var user = *authCtx.currentUser

        var nameOpt = req.param("name")
        var versionOpt = req.param("version")

        if !nameOpt || !versionOpt {
            response.badRequest(resp, "Missing package name or version".S)
            return
        }

        var name = *nameOpt
        var version = *versionOpt

        // Check ownership or admin
        var pkgOpt = ctx.repo.getPackageSummary(__copy!(name)) catch {
            response.internalError(resp, f"Failed to fetch package: {ex!.what()}")
            return
        }

        if !pkgOpt {
            response.notFound(resp, f"Package not found: {name}")
            return
        }

        var pkg = *pkgOpt
        if pkg.owner_user_id != user.id && !user.is_admin {
            response.forbidden(resp, "Only the package owner or an admin can yank versions".S)
            return
        }

        ctx.repo.yankVersion(__copy!(name), __copy!(version)) catch {
            response.internalError(resp, f"Failed to yank version: {ex!.what()}")
            return
        }

        response.jsonResponse(resp, &MessageResponse("Version yanked successfully".S))
    }))

    // Unyank version (owner or admin)
    auth.requireUser(ep("POST /api/v1/packages/{name}/{version}/unyank", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var user = *authCtx.currentUser

        var nameOpt = req.param("name")
        var versionOpt = req.param("version")

        if !nameOpt || !versionOpt {
            response.badRequest(resp, "Missing package name or version".S)
            return
        }

        var name = *nameOpt
        var version = *versionOpt

        // Check ownership or admin
        var pkgOpt = ctx.repo.getPackageSummary(__copy!(name)) catch {
            response.internalError(resp, f"Failed to fetch package: {ex!.what()}")
            return
        }

        if !pkgOpt {
            response.notFound(resp, f"Package not found: {name}")
            return
        }

        var pkg = *pkgOpt
        if pkg.owner_user_id != user.id && !user.is_admin {
            response.forbidden(resp, "Only the package owner or an admin can unyank versions".S)
            return
        }

        ctx.repo.unyankVersion(__copy!(name), __copy!(version)) catch {
            response.internalError(resp, f"Failed to unyank version: {ex!.what()}")
            return
        }

        response.jsonResponse(resp, &MessageResponse("Version unyanked successfully".S))
    }))

    // Publish package (requires any authenticated user or admin via API key)
    auth.requireUser(ep("POST /api/v1/packages", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var user = *authCtx.currentUser
        var request = parse[PublishRequest](req.body().__str()) catch {
            response.badRequest(resp, f"Invalid JSON: {ex!.what()}")
            return
        }
        handlePublishPackage(resp, ctx.repo, &ctx.registryUrl, &request, user.id)
    }))
}

/// Register user API key management endpoints
pub func userKeys(ep: &Endpoint): void {
    var auth = ep.middleware[AuthMiddleware]()

    // List user's API keys
    auth.requireUser(ep("GET /api/v1/user/keys", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var user = *authCtx.currentUser

        var keys = ctx.repo.getUserApiKeys(user.id) catch {
            response.internalError(resp, f"Failed to list API keys: {ex!.what()}")
            return
        }

        response.jsonResponse(resp, &keys)
    }))

    // Create API key
    auth.requireUser(ep("POST /api/v1/user/keys", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var user = *authCtx.currentUser


        var request = parse[CreateApiKeyRequest](req.body().__str()) catch {
            response.badRequest(resp, f"Invalid JSON: {ex!.what()}")
            return
        }

        if request.name == null || request.name.empty() {
            response.badRequest(resp, "Missing required field: name".S)
            return
        }

        // Only admins can create admin-scoped keys
        if request.hasAdminScope() && !user.is_admin {
            response.forbidden(resp, "Admin scope requires admin privileges".S)
            return
        }

        var pair = ctx.repo.createApiKey(
            user.id,
            __copy!(request.name),
            &request.scopes,
            __copy!(request.expires_at)
        ) catch {
            response.internalError(resp, f"Failed to create API key: {ex!.what()}")
            return
        }

        var plainKey, apiKey = pair
        var result = CreateApiKeyResponse(&&plainKey, &&apiKey)
        response.jsonResponse(resp, &result, Status.Create)
    }))

    // Revoke API key
    auth.requireUser(ep("DELETE /api/v1/user/keys/{id}", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var user = *authCtx.currentUser

        var idOpt = req.param("id")
        if !idOpt {
            response.badRequest(resp, "Missing key id".S)
            return
        }

        var keyId = idOpt&.toi[i64]()

        ctx.repo.revokeApiKey(keyId, user.id) catch {
            response.internalError(resp, f"Failed to revoke API key: {ex!.what()}")
            return
        }

        resp.end(Status.NoContent)
    }))
}

/// Register admin endpoints
pub func admin(ep: &Endpoint): void {
    var auth = ep.middleware[AuthMiddleware]()

    // Make user admin
    auth.requireAdmin(ep("POST /api/v1/admin/users/{id}/make-admin", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var currentUser = *authCtx.currentUser

        var idOpt = req.param("id")
        if !idOpt {
            response.badRequest(resp, "Missing user id".S)
            return
        }

        var userId = idOpt&.toi[i64]()

        if userId == currentUser.id {
            response.badRequest(resp, "Cannot grant admin to yourself".S)
            return
        }

        var userOpt = ctx.repo.getUser(userId) catch {
            response.internalError(resp, f"Failed to fetch user: {ex!.what()}")
            return
        }
        if !userOpt {
            response.notFound(resp, f"User not found: {userId}")
            return
        }

        ctx.repo.setUserAdmin(userId, true, currentUser.id, __copy!(currentUser.login)) catch {
            response.internalError(resp, f"Failed to grant admin: {ex!.what()}")
            return
        }

        resp.header("Content-Type", "application/json; charset=utf-8")
        resp.body() << "{\"message\":\"Admin granted successfully\"}"
        resp.end(Status.Ok)
    }))

    // Revoke user admin
    auth.requireAdmin(ep("POST /api/v1/admin/users/{id}/revoke-admin", (req: &const Request, resp: &Response) => {
        var ctx = ep.context[RepoProvider](req)
        var authCtx = ep.context[AuthMiddleware](req)
        var currentUser = *authCtx.currentUser

        var idOpt = req.param("id")
        if !idOpt {
            response.badRequest(resp, "Missing user id".S)
            return
        }

        var userId = idOpt&.toi[i64]()

        if userId == currentUser.id {
            response.badRequest(resp, "Cannot revoke your own admin".S)
            return
        }

        var userOpt = ctx.repo.getUser(userId) catch {
            response.internalError(resp, f"Failed to fetch user: {ex!.what()}")
            return
        }
        if !userOpt {
            response.notFound(resp, f"User not found: {userId}")
            return
        }

        ctx.repo.setUserAdmin(userId, false, 0, null) catch {
            response.internalError(resp, f"Failed to revoke admin: {ex!.what()}")
            return
        }

        resp.header("Content-Type", "application/json; charset=utf-8")
        resp.body() << "{\"message\":\"Admin revoked successfully\"}"
        resp.end(Status.Ok)
    }))
}

// ============================================================================
// Handler Implementations
// ============================================================================

/// Health check handler
func handleHealth(resp: &Response): void {
    var health = HealthResponse("ok".S, "1.0.0".S)
    response.jsonResponse(resp, &health)
}

/// Search or list packages handler
func handleSearchPackages(
    resp: &Response,
    repo: &PackageRepository,
    query: __string?,
    limit: i32,
    offset: i32,
    sort: __string
): void {
    if !query {
        var result = repo.listPackages(limit, offset, sort) catch {
            response.internalError(resp, f"Search failed: {ex!.what()}")
            return
        }
        response.jsonResponse(resp, &result)
    } else {
        var result = repo.searchPackages(*query, limit, offset, sort) catch {
            response.internalError(resp, f"Search failed: {ex!.what()}")
            return
        }
        response.jsonResponse(resp, &result)
    }
}

/// Get package details handler
func handleGetPackage(resp: &Response, repo: &PackageRepository, name: __string): void {
    var pkgOpt = repo.getPackage(name) catch {
        response.internalError(resp, f"Database error: {ex!.what()}")
        return
    }

    if !pkgOpt {
        response.notFound(resp, f"Package not found: {name}")
        return
    }

    // Strip readme from API response — fetch it separately via /readme
    var details = *pkgOpt
    details.pkg.readme = null

    response.jsonResponse(resp, &details)
}

/// Get package README as raw markdown
func handleGetReadme(resp: &Response, repo: &PackageRepository, name: __string): void {
    var pkgOpt = repo.getPackage(name) catch {
        response.internalError(resp, f"Database error: {ex!.what()}")
        return
    }

    if !pkgOpt {
        response.notFound(resp, f"Package not found: {name}")
        return
    }

    var details = *pkgOpt
    if details.pkg.readme == null || details.pkg.readme.empty() {
        resp.end(Status.NoContent)
        return
    }

    resp.header("Content-Type", "text/markdown; charset=utf-8")
    resp.body() << details.pkg.readme
    resp.end(Status.Ok)
}

/// List versions handler
func handleListVersions(resp: &Response, repo: &PackageRepository, name: __string): void {
    var versions = repo.listVersions(name) catch {
        response.internalError(resp, f"Database error: {ex!.what()}")
        return
    }

    var result = VersionsResponse(String(name), &&versions)
    response.jsonResponse(resp, &result)
}

/// Get specific version handler
func handleGetVersion(
    resp: &Response,
    repo: &PackageRepository,
    name: __string,
    version: __string
): void {
    var versionOpt = repo.getVersion(name, version) catch {
        response.internalError(resp, f"Database error: {ex!.what()}")
        return
    }

    if !versionOpt {
        response.notFound(resp, f"Version not found: {name}@{version}")
        return
    }

    response.jsonResponse(resp, versionOpt.ref())
}

/// Record download handler
func handleDownload(resp: &Response, repo: &PackageRepository, name: __string, version: __string): void {
    repo.recordDownload(name, version)
    resp.end(Status.NoContent)
}

/// Publish package handler
func handlePublishPackage(resp: &Response, repo: &PackageRepository, registryUrl: &String, request: &PublishRequest, ownerId: i64): void {
    // Validate required metadata fields
    if request.metadata.name == null || request.metadata.name.empty() {
        response.badRequest(resp, "Missing required field: metadata.name".S)
        return
    }
    if request.metadata.version == null || request.metadata.version.empty() {
        response.badRequest(resp, "Missing required field: metadata.version".S)
        return
    }

    var _ = repo.publishPackage(request, ownerId) catch {
        response.internalError(resp, f"Publish failed: {ex!.what()}")
        return
    }

    var result = PublishResponse(
        __copy!(request.metadata.name),
        __copy!(request.metadata.version),
        f"{registryUrl}/packages/{request.metadata.name}"
    )

    response.jsonResponse(resp, &result, Status.Create)
}



// ============================================================================
// Response Models
// ============================================================================

@json
pub struct MessageResponse {
    message: String = null

    func `init`(message: String) {
        this.message = &&message
    }
}

@json
pub struct HealthResponse {
    status: String = null
    version: String = null

    func `init`(status: String, version: String) {
        this.status = &&status
        this.version = &&version
    }
}

@json
pub struct VersionsResponse {
    name: String = null
    versions: Vector[VersionSummary] = null

    func `init`(name: String, versions: Vector[VersionSummary]) {
        this.name = &&name
        this.versions = &&versions
    }
}

@json
pub struct PublishResponse {
    name: String = null
    version: String = null
    url: String = null

    func `init`(name: String, version: String, url: String) {
        this.name = &&name
        this.version = &&version
        this.url = &&url
    }
}

@json(partial: true)
pub struct CreateApiKeyRequest {
    name: String = null
    scopes: Vector[String] = null
    expires_at: String = null       // ISO 8601 date (null = never expires)

    func hasAdminScope(): bool {
        if scopes == null {
            return false
        }
        for scope, _ in scopes {
            if scope == "admin" {
                return true
            }
        }
        return false
    }
}

@json
pub struct CreateApiKeyResponse {
    key: String = null              // Plain text key - shown ONCE
    id: i64 = 0
    name: String = null
    scopes: Vector[String] = null
    created_at: String = null
    expires_at: String = null

    func `init`(key: String, apiKey: ApiKey) {
        this.key = &&key
        this.id = apiKey.id
        this.name = __copy!(apiKey.name)
        this.scopes = &&apiKey.scopes
        this.created_at = __copy!(apiKey.created_at)
        this.expires_at = __copy!(apiKey.expires_at)
    }
}
